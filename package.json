{
  "name": "auraxis-app",
  "main": "expo-router/entry",
  "version": "1.3.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint --max-warnings 0 -- --no-error-on-unmatched-pattern",
    "prepare": "husky",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "flags:check": "node scripts/check-feature-flags.cjs",
    "contracts:sync": "node scripts/contracts-sync.cjs",
    "contracts:sync:api-local": "node scripts/contracts-sync-local-api.cjs",
    "contracts:catalog:check": "node scripts/app-contract-catalog-check.cjs",
    "contracts:check": "node scripts/contracts-check.cjs",
    "policy:check": "node scripts/check-frontend-governance.cjs && node scripts/check-api-contract-governance.cjs && node scripts/check-app-route-boundaries.cjs && node scripts/check-openapi-secret-hygiene.cjs && node scripts/check-sonar-config-governance.cjs && node scripts/check-runtime-release-governance.cjs && node scripts/check-client-security-governance.cjs && node scripts/check-client-logging-governance.cjs",
    "quality-check": "npm run lint && npm run typecheck && npm run policy:check && npm run contracts:check && npm run test:coverage",
    "test:watch": "jest --watchAll",
    "ci:local": "bash scripts/run_ci_like_actions_local.sh",
    "e2e": "maestro test .maestro/",
    "e2e:login": "maestro test .maestro/01_login.yaml"
  },
  "dependencies": {
    "@expo-google-fonts/playfair-display": "^0.4.2",
    "@expo-google-fonts/raleway": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^5.2.2",
    "@react-navigation/bottom-tabs": "^7.15.10",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@sentry/react-native": "^8.4.0",
    "@tanstack/react-query": "^5.99.0",
    "axios": "^1.15.2",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-secure-store": "^55.0.13",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.6",
    "react-dom": "19.1.5",
    "react-hook-form": "^7.72.1",
    "react-native": "0.81.6",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.1",
    "tamagui": "^2.0.0-rc.34",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "husky": "^9.1.7",
    "jest-expo": "^54.0.17",
    "lint-staged": "^16.3.2",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.1.5",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": "25.x"
  },
  "private": true,
  "overrides": {
    "tar": "7.5.11",
    "@xmldom/xmldom": "^0.8.13"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored",
      "node scripts/check-frontend-governance.cjs",
      "node scripts/check-api-contract-governance.cjs",
      "node scripts/check-app-route-boundaries.cjs",
      "node scripts/check-openapi-secret-hygiene.cjs",
      "node scripts/check-client-security-governance.cjs",
      "node scripts/check-client-logging-governance.cjs"
    ],
    "**/*.json": [
      "prettier --write",
      "node scripts/check-openapi-secret-hygiene.cjs"
    ],
    "{package.json,package-lock.json,.nvmrc,app.json,eas.json,README.md,CODING_STANDARDS.md,steering.md,.context/quality_gates.md,.context/architecture.md,.github/workflows/ci.yml,.github/workflows/deploy-minimum.yml,.github/workflows/store-release.yml,scripts/run_ci_like_actions_local.sh}": [
      "node scripts/check-runtime-release-governance.cjs",
      "node scripts/check-client-security-governance.cjs",
      "node scripts/check-client-logging-governance.cjs"
    ]
  }
}
